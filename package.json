{
	"name": "grand-oral-finder",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.4.2",
			"zod": "^4.4.3",
			"typescript": "^6",
			"@types/bun": "^1.3.14",
			"hono": "^4.12.27",
			"@orpc/server": "^1.14.6",
			"@orpc/openapi": "^1.14.6",
			"@orpc/zod": "^1.14.6",
			"lucide-react": "^1.23.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.7",
			"react-dom": "^19.2.7",
			"sonner": "^2.0.7",
			"@orpc/client": "^1.14.6",
			"@tailwindcss/postcss": "^4.3.2",
			"@types/react": "^19.2.17",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.3.2"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"test": "bun test",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:push": "bun --cwd packages/db db:push",
		"db:studio": "bun --cwd packages/db db:studio",
		"db:generate": "bun --cwd packages/db db:generate",
		"db:migrate": "bun --cwd packages/db db:migrate",
		"db:seed:test": "bun --cwd apps/server seed:test",
		"docker:build": "docker compose build",
		"docker:up": "docker compose up -d --build",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@grand-oral-finder/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@grand-oral-finder/config": "workspace:*",
		"@types/bun": "catalog:",
		"turbo": "^2.10.2",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.14"
}
