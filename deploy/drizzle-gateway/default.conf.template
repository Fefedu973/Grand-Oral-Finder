map $http_authorization $adapter_authorized {
    default 0;
    "Bearer ${GATEWAY_ADAPTER_TOKEN}" 1;
}

server {
    listen 8080;
    server_name _;

    location / {
        if ($adapter_authorized = 0) {
            return 401;
        }

        proxy_http_version 1.1;
        proxy_set_header Authorization "Basic ${LIBSQL_BASIC_AUTH}";
        proxy_set_header Host "${LIBSQL_HOST}";
        proxy_pass http://${LIBSQL_HOST}:8080;
    }
}
